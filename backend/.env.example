APP_NAME=Prompt Dairy
APP_ENV=development
FRONTEND_URL=http://localhost:3000

# Supabase (optional for local dev — articles/challenges/roadmaps use built-in mock data when unset)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Async driver: postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=

# Must match Supabase JWT secret (Dashboard → Settings → API → JWT Secret) for /auth/* and protected routes
JWT_SECRET=dev-secret-change-in-production
JWT_ALGORITHM=HS256

# Optional — real model calls in playground when set
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OPENROUTER_API_KEY=
